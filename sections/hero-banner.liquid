{% liquid
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif

  assign widths = '750, 1100, 1500, 1780, 2000, 3000'
  assign sizes = '100vw'
%}

<div
  id="HeroBanner-{{ section.id }}"
  class="hero-banner color-{{ section.settings.color_scheme }}"
  style="
    --hero-banner-min-height: {{ section.settings.section_height }};
    --hero-banner-content-alignment: {{ section.settings.content_alignment }};
    {% render 'spacing-style', settings: section.settings %}
  "
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div class="hero-banner__media-wrapper">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 3000
        | image_tag:
          loading: 'lazy',
          fetchpriority: fetch_priority,
          widths: widths,
          sizes: sizes,
          width: section.settings.image.width,
          height: section.settings.image.height,
          class: 'hero-banner__image',
          alt: section.settings.image.alt | escape
      }}
    {%- else -%}
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'hero-banner__image hero-banner__image--placeholder' }}
    {%- endif -%}

    {%- if section.settings.toggle_overlay -%}
      {% render 'overlay', settings: section.settings %}
    {%- endif -%}
  </div>

  <div class="hero-banner__content-wrapper">
    <div class="hero-banner__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="hero-banner__heading">{{ section.settings.heading | newline_to_br }}</h2>
      {%- endif -%}

      {%- if section.settings.button_1_label != blank or section.settings.button_2_label != blank -%}
        <div class="hero-banner__cta-group">
          {%- if section.settings.button_1_label != blank -%}
            <a
              href="{{ section.settings.button_1_url | default: '#' }}"
              class="hero-banner__btn"
            >
              {{- section.settings.button_1_label -}}
            </a>
          {%- endif -%}

          {%- if section.settings.button_2_label != blank -%}
            <a
              href="{{ section.settings.button_2_url | default: '#' }}"
              class="hero-banner__btn"
            >
              {{- section.settings.button_2_label -}}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-banner {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: var(--hero-banner-min-height, 60svh);
    overflow: hidden;
  }

  .hero-banner[data-shopify-visual-preview] {
    min-height: 600px;
  }

  .hero-banner__media-wrapper {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-banner__image--placeholder {
    background-color: rgb(var(--color-background-rgb));
  }

  .hero-banner__content-wrapper {
    position: relative;
    z-index: var(--layer-flat, 1);
    width: 100%;
    padding: 4rem;
  }

  .hero-banner__content {
    display: flex;
    flex-direction: column;
    align-items: var(--hero-banner-content-alignment, center);
    gap: 1.5rem;
    width: 100%;
  }

  .hero-banner__heading {
    font-family: var(--font-primary--family);
    font-weight: var(--font-primary--weight, 400);
    font-size: clamp(2rem, 3.5vw, 2.5rem);
    line-height: 1.2;
    color: rgb(var(--color-foreground-rgb));
    text-align: center;
    margin: 0;
  }

  .hero-banner__cta-group {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 3rem;
    padding: 0.25rem 2rem;
    border-radius: 1.5rem;
    background-color: #ffffff;
    border: 1px solid #00165a;
    color: #00165a;
    font-family: var(--font-accent--family);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.125rem;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .hero-banner__btn:hover {
    background-color: #00165a;
    color: #ffffff;
  }

  @media screen and (max-width: 749px) {
    .hero-banner {
      min-height: 500px;
    }

    .hero-banner__content-wrapper {
      padding: 2rem 1.5rem;
    }

    .hero-banner__cta-group {
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .hero-banner__btn {
      width: 100%;
      max-width: 280px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-banner-wrapper section-wrapper",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        { "value": "50svh", "label": "Small" },
        { "value": "60svh", "label": "Medium" },
        { "value": "80svh", "label": "Large" },
        { "value": "100svh", "label": "Full screen" }
      ],
      "default": "80svh"
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "toggle_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "alpha": true,
      "default": "#00000026",
      "visible_if": "{{ section.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "overlay_style",
      "label": "Overlay style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "gradient", "label": "Gradient" }
      ],
      "default": "gradient",
      "visible_if": "{{ section.settings.toggle_overlay }}"
    },
    {
      "type": "select",
      "id": "gradient_direction",
      "label": "Gradient direction",
      "options": [
        { "value": "to top", "label": "Up" },
        { "value": "to bottom", "label": "Down" }
      ],
      "default": "to top",
      "visible_if": "{{ section.settings.toggle_overlay and section.settings.overlay_style == 'gradient' }}"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Worn for the Journey,\nMade from the Tide"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_1_url",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Label"
    },
    {
      "type": "url",
      "id": "button_2_url",
      "label": "Link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Banners",
      "settings": {
        "section_height": "80svh",
        "toggle_overlay": true,
        "overlay_style": "gradient",
        "gradient_direction": "to top",
        "content_alignment": "center",
        "color_scheme": "scheme-5"
      }
    }
  ]
}
{% endschema %}
